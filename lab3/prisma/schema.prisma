generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // ใช้ SQLite เพราะง่ายที่สุดสำหรับการทดลองรัน ไม่ต้องลง DB เพิ่ม
  url = "file:./dev.db"
}

model Author {
  id    Int     @id @default(autoincrement())
  name  String
  bio   String?
  books Book[]            
}

model Book {
  id         Int        @id @default(autoincrement())
  title      String
  published  Boolean    @default(false)
  author     Author     @relation(fields: [authorId], references: [id])
  authorId   Int
  categories Category[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  books Book[]
}
